# AIOS Kernel Configuration
# Copy this file to .env and fill in your values

# --- API Keys ---
# Google Gemini (Required)
GEMINI_API_KEY=your_gemini_api_key_here
# Optional: Multiple keys for rotation (comma separated)
GEMINI_API_KEYS=key1,key2,key3

# OpenAI (Optional)
OPENAI_API_KEYS=sk-...,sk-...

# Anthropic (Optional)
ANTHROPIC_API_KEYS=sk-ant-...,sk-ant-...

# --- Model Configuration ---
DEFAULT_MODEL=gemini-2.0-flash
LOCAL_MODEL=mistral

# --- Sandbox Configuration ---
# Set to True to enable Docker-based sandboxing for code execution
ENABLE_DOCKER_SANDBOX=False
DOCKER_IMAGE=python:3.10-slim

# --- Paths ---
# By default, workspace is set to project_root/storage
# You can override it here if needed
# WORKSPACE_ROOT=/path/to/custom/workspace
