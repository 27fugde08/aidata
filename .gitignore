# AIOS Git Ignore

# Byte-compiled / optimized / DLL files
__pycache__/
*.py[cod]
*$py.class

# OS generated files
.DS_Store
Thumbs.db

# Environments
.env
.venv
env/
venv/
ENV/

# Data & Storage (CRITICAL: Ignore large binaries)
storage/
data/
spaceofduy/
test_workspace/
*.sqlite3
*.sqlite
*.db

# Logs
logs/
*.log

# Multimedia
*.mp4
*.mp3
*.wav
*.mov
*.avi
*.ass
*.srt

# Docker
.dockerignore

# IDEs
.vscode/
.idea/
